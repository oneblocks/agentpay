# 基础配置
PORT=9000
# 如果 Router 运行在 443 端口：
# 1. 如果使用了 HTTPS (有证书): ROUTER_URL=https://your-domain.com
# 2. 如果只是普通的 HTTP 跑在 443: ROUTER_URL=http://your-domain.com:443
ROUTER_URL=http://api.agentpay.space:8080

# AgentPay 注册信息
AGENT_NAME=MyExpertAgent
AGENT_RECIPIENT={your eth address}
AGENT_PRICE={price}
AGENT_ENDPOINT=http://{your_ip}:9000/chat
AGENT_DESCRIPTION=这是一个擅长特定领域的专家 Agent

# 模型后端配置 (如果你调用第三方 AI)
PROVIDER_API_KEY={sk}
PROVIDER_BASE_URL={url}
PROVIDER_MODEL={model}
